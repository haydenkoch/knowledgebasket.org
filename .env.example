# Production or staging environment template.
# Set these in your hosting provider's environment-variable UI instead of committing a real .env file.

# Optional: Mapbox access token for event location/address geocoding (server).
# Get a token at https://account.mapbox.com/access-tokens/
# MAPBOX_ACCESS_TOKEN="pk_your_production_token"

# Core runtime
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB_NAME"
BETTER_AUTH_SECRET="generate-a-random-32-plus-character-secret"
ORIGIN="https://kb.example.com"
# If you are bootstrapping on Railway before setting a custom domain:
# RAILWAY_PUBLIC_DOMAIN="your-app.up.railway.app"

# Better Auth social login
# Google OAuth redirect URI: ${ORIGIN}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP (required in production for sign-up verification, password reset, and email changes)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_REQUIRE_TLS="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"Knowledge Basket\" <noreply@example.com>"

# Sentry (errors + performance)
PUBLIC_SENTRY_DSN="https://public-key@o0.ingest.us.sentry.io/0"
SENTRY_DSN="https://public-key@o0.ingest.us.sentry.io/0"
PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_TRACES_SAMPLE_RATE="0.1"
PUBLIC_SENTRY_ENABLE_DEV="false"
PUBLIC_SENTRY_ENVIRONMENT="production"
PUBLIC_SENTRY_RELEASE=""

# Optional: enable source map uploads during build.
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_RELEASE=""
# SENTRY_ENVIRONMENT="production"

# PostHog (product analytics + session replay)
PUBLIC_POSTHOG_KEY="phc_your_project_api_key"
PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Object storage
MINIO_ENDPOINT="https://s3.example.com"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET="kb-uploads"
PUBLIC_ASSET_BASE_URL="https://assets.example.com/kb-uploads"

# Search
MEILISEARCH_HOST="https://search.example.com"
MEILISEARCH_API_KEY=""

# Protected operational endpoints
REINDEX_SECRET="generate-a-random-secret"
SOURCE_OPS_SECRET="generate-a-random-secret"

# Structured server logging / alert fan-out
LOG_LEVEL="info"
# ERROR_WEBHOOK_URL="https://hooks.example.com/alerts"

# Redis (optional)
# REDIS_URL="redis://HOST:6379"

# Optional: resources directory for static PDFs/assets
# KB_RESOURCES_PATH="/path/to/resources"
