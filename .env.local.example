# Local development template.
# Copy this file to `.env` for everyday local development.

# Optional: Mapbox access token for event location/address geocoding (server).
# Get a token at https://account.mapbox.com/access-tokens/
# When set, Mapbox results appear first; Photon + Census still fill in when Mapbox has no match.
# MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Drizzle / Postgres (use these values when running docker compose from repo root)
DATABASE_URL="postgres://kb:kbdev@localhost:5432/kb"

# Better Auth
# For production use 32 characters and generated with high entropy.
BETTER_AUTH_SECRET="local-dev-secret-change-me-for-production"
ORIGIN="http://localhost:5173"
# Google OAuth redirect URI: ${ORIGIN}/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# SMTP (optional locally unless you want email verification and password reset flows to send mail)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_REQUIRE_TLS="true"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="\"Knowledge Basket\" <noreply@example.com>"

# Sentry (optional locally)
# PUBLIC_SENTRY_DSN="https://public-key@o0.ingest.us.sentry.io/0"
# SENTRY_DSN="https://public-key@o0.ingest.us.sentry.io/0"
# PUBLIC_SENTRY_TRACES_SAMPLE_RATE="1"
# SENTRY_TRACES_SAMPLE_RATE="1"
# PUBLIC_SENTRY_ENABLE_REPLAY="true"
# PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE="1"
# PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE="1"
# PUBLIC_SENTRY_ENABLE_FEEDBACK="true"
# PUBLIC_SENTRY_FEEDBACK_AUTO_INJECT="true"
# PUBLIC_SENTRY_ENABLE_DEV="true"
# PUBLIC_SENTRY_ENVIRONMENT="development"
# PUBLIC_SENTRY_RELEASE=""
# SENTRY_ENABLE_LOGS="true"

# PostHog (optional locally; current app only initializes it outside `pnpm dev`)
# PUBLIC_POSTHOG_KEY="phc_your_project_api_key"
# PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# MinIO (S3-compatible storage). Match docker-compose env when using local Docker.
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="kbminio"
MINIO_SECRET_KEY="kbminio123"
MINIO_BUCKET="kb-uploads"
PUBLIC_ASSET_BASE_URL="http://localhost:9000/kb-uploads"

# Meilisearch (search). Match docker-compose env from the repo root.
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="kbdev"

# Protected operational endpoints
REINDEX_SECRET="local-reindex-secret"
SOURCE_OPS_SECRET="local-source-ops-secret"

# Structured server logging / alert fan-out
LOG_LEVEL="info"
# ERROR_WEBHOOK_URL=""

# Redis (optional: sessions, cache). Use when running docker compose.
# REDIS_URL="redis://localhost:6379"

# Optional: resources directory for static PDFs/assets
# KB_RESOURCES_PATH="/path/to/resources"
