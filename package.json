{
	"name": "site",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@10.32.1",
	"type": "module",
	"engines": {
		"node": "24.x",
		"pnpm": "10.x"
	},
	"pnpm": {
		"overrides": {
			"picomatch": "^4.0.4"
		}
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "pnpm db:migrate && node build/index.js",
		"start:app": "node build/index.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:ci": "node scripts/run-changed-lint-ci.mjs",
		"test": "vitest run --maxWorkers=1",
		"test:unit:ci": "node scripts/run-vitest-ci.mjs unit",
		"test:http:ci": "node scripts/run-vitest-ci.mjs http",
		"test:search:indexed": "SEARCH_INDEXED_MODE_TEST=1 node scripts/run-vitest-ci.mjs search-indexed",
		"test:search:degraded": "SEARCH_DEGRADED_MODE_TEST=1 node scripts/run-vitest-ci.mjs search-degraded",
		"test:e2e": "playwright test",
		"test:e2e:ci": "node scripts/run-playwright-ci.mjs",
		"format": "prettier --write .",
		"secrets:check": "tsx scripts/check-secrets.ts",
		"secrets:check:ci": "tsx scripts/check-secrets.ts --environment=ci",
		"secrets:check:staging": "tsx scripts/check-secrets.ts --environment=staging",
		"secrets:check:production": "tsx scripts/check-secrets.ts --environment=production",
		"db:push": "drizzle-kit push",
		"db:deploy": "drizzle-kit migrate",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"db:seed": "node scripts/seed-launch.mjs",
		"db:seed:ci": "node scripts/seed-ci.mjs",
		"funding:sync": "node scripts/sync-curated-funding.mjs",
		"db:seed:events": "node scripts/seed-events.js",
		"db:seed:coils": "node scripts/seed-coils.js",
		"db:seed:sources": "tsx scripts/seed-sources.ts",
		"images:process": "node scripts/process-landscape-images.mjs",
		"images:sync": "node scripts/sync-static-images-to-minio.mjs",
		"assets:normalize-legacy": "tsx scripts/normalize-legacy-public-assets.ts"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^24",
		"@types/nodemailer": "^7.0.11",
		"@types/sanitize-html": "^2.16.1",
		"better-auth": "~1.4.21",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"dotenv": "^16.6.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"formsnap": "^2.0.1",
		"globals": "^17.3.0",
		"layerchart": "2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"sharp": "^0.33.5",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^7.3.2",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1024.0",
		"@schedule-x/calendar": "^4.3.1",
		"@schedule-x/events-service": "^4.3.1",
		"@schedule-x/svelte": "^3.0.0",
		"@schedule-x/theme-shadcn": "^4.3.1",
		"@sentry/sveltekit": "^10.47.0",
		"cheerio": "^1.2.0",
		"csv-parse": "^6.2.1",
		"exceljs": "^4.4.0",
		"fast-xml-parser": "^5.5.9",
		"mapbox-gl": "^3.19.1",
		"meilisearch": "^0.55.0",
		"node-ical": "^0.25.5",
		"nodemailer": "^8.0.4",
		"pdfjs-dist": "^5.6.205",
		"posthog-js": "^1.364.7",
		"sanitize-html": "^2.17.2",
		"site": "link:",
		"svelte-dnd-action": "^0.9.69",
		"temporal-polyfill": "^0.3.2",
		"tinymce": "^8.3.2"
	}
}
