	{
		"name": "NCAI Events Calendar",
		"slug": "ncai-events",
		"description": "National Congress of American Indians event calendar. Major tribal conferences and conventions.",
		"source_url": "https://www.ncai.org/events",
		"homepage_url": "https://www.ncai.org/",
		"coils": ["events"],
		"ingestion_method": "html_scrape",
		"source_category": "nonprofit",
		"adapter_type": "html_selector",
		"fetch_cadence": "weekly",
		"adapter_config": {
			"base_url": "https://www.ncai.org",
			"itemSelector": "a[href^='/event/']:has(.styles_title__srpcf)",
			"maxItems": 40,
			"fieldRules": {
				"title": {
					"selector": ".styles_title__srpcf",
					"extract": "text",
					"transform": "trim"
				},
				"date": {
					"selector": ".styles_description__Diaz_",
					"extract": "text",
					"transform": "trim"
				},
				"url": {
					"selector": ":scope",
					"extract": "href"
				},
				"image_url": {
					"selector": "img",
					"extract": "src"
				}
			}
		},
		"confidence_score": 4,
		"risk_profile": {
			"freshness": "medium",
			"duplication": "medium",
			"legal": "low",
			"normalization": "medium",
			"maintenance": "medium",
			"moderation": "medium"
		},
		"dedupe_strategies": ["composite_key", "url_match", "title_fuzzy"],
		"attribution_required": true,
		"attribution_text": "Source: National Congress of American Indians",
		"review_required": true,
		"steward_notes": "HTML scraping needed. Page structure may change. Major national events only."
	},
